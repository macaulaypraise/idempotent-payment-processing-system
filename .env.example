# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/payments_db

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PAYMENT_INITIATED=payment.initiated
KAFKA_TOPIC_PAYMENT_COMPLETED=payment.completed
KAFKA_TOPIC_PAYMENT_FAILED=payment.failed
KAFKA_TOPIC_DLQ=payment.dlq
KAFKA_CONSUMER_GROUP=settlement-worker

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_LOCK_TTL_SECONDS=30

# Payment
PAYMENT_PROVIDER_URL=http://mock-provider:8001/charge
PAYMENT_PROVIDER_TIMEOUT_SECONDS=10
PAYMENT_MAX_RETRIES=5
PAYMENT_RETRY_BASE_DELAY_SECONDS=1

# Outbox poller
OUTBOX_BATCH_SIZE=100
OUTBOX_IDLE_SLEEP_SECONDS=2

# Observability
LOG_LEVEL=INFO
SERVICE_NAME=ipps-payment-api
METRICS_PATH=/metrics

# Grafana (local only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
